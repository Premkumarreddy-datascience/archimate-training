<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="Variant A - Azure-native Teams Bot" id="id-variant-a-main" version="5.0.0">
  <folder name="Motivation" id="id-motivation" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Legal &amp; compliance" id="id-stakeholder-legal"/>
    <element xsi:type="archimate:Stakeholder" name="IT operations (Ecolab)" id="id-stakeholder-itops"/>
    <element xsi:type="archimate:Driver" name="Reduce search friction" id="id-driver-search"/>
    <element xsi:type="archimate:Driver" name="Honour existing permissions" id="id-driver-permissions"/>
    <element xsi:type="archimate:Goal" name="Multi‑turn conversation" id="id-goal-multiturn"/>
    <element xsi:type="archimate:Goal" name="Citations required" id="id-goal-citations"/>
    <element xsi:type="archimate:Goal" name="Fast time‑to‑pilot" id="id-goal-fastpilot"/>
    <element xsi:type="archimate:Requirement" name="Entra ID SSO" id="id-req-sso"/>
    <element xsi:type="archimate:Requirement" name="SharePoint permission enforcement" id="id-req-acl"/>
    <element xsi:type="archimate:Requirement" name="Natural language Q&amp;A" id="id-req-nlq"/>
    <element xsi:type="archimate:Requirement" name="Teams integration" id="id-req-teams"/>
    <element xsi:type="archimate:Requirement" name="Multi‑turn support" id="id-req-multiturn"/>
  </folder>
  <folder name="Business" id="id-business" type="business">
    <element xsi:type="archimate:BusinessActor" name="Water frontline colleague" id="id-actor-frontline"/>
    <element xsi:type="archimate:BusinessActor" name="Water shift supervisor" id="id-actor-supervisor"/>
    <element xsi:type="archimate:BusinessActor" name="Water safety officer" id="id-actor-safety"/>
    <element xsi:type="archimate:BusinessService" name="Answer service" id="id-service-answer"/>
    <element xsi:type="archimate:BusinessService" name="Citation service" id="id-service-citation"/>
  </folder>
  <folder name="Application" id="id-application" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="Teams Bot" id="id-comp-bot"/>
    <element xsi:type="archimate:ApplicationComponent" name="RAG Orchestrator" id="id-comp-orchestrator"/>
    <element xsi:type="archimate:ApplicationComponent" name="Azure AI Search" id="id-comp-search"/>
    <element xsi:type="archimate:ApplicationComponent" name="Azure OpenAI" id="id-comp-openai"/>
    <element xsi:type="archimate:ApplicationComponent" name="Cosmos DB" id="id-comp-cosmos"/>
    <element xsi:type="archimate:DataObject" name="Conversation state" id="id-data-convstate"/>
    <element xsi:type="archimate:ApplicationService" name="SharePoint Online" id="id-ext-sharepoint"/>
    <element xsi:type="archimate:ApplicationService" name="Entra ID" id="id-ext-entraid"/>
    <element xsi:type="archimate:ApplicationService" name="ACL trimming service" id="id-svc-acltrim"/>
    <element xsi:type="archimate:ApplicationService" name="Indexer with ACL pull" id="id-svc-indexer"/>
    <element xsi:type="archimate:ApplicationInteraction" name="Chat interface" id="id-intf-chat"/>
    <element xsi:type="archimate:ApplicationInteraction" name="Search interface" id="id-intf-search"/>
    <element xsi:type="archimate:ApplicationInteraction" name="Completion interface" id="id-intf-completion"/>
    <element xsi:type="archimate:ApplicationService" name="OAuth2 OBO flow" id="id-svc-obo"/>
  </folder>
  <folder name="Technology" id="id-technology" type="technology">
    <element xsi:type="archimate:Node" name="Azure App Service" id="id-node-appsvc"/>
    <element xsi:type="archimate:Node" name="Azure AI Search service" id="id-node-searchsvc"/>
    <element xsi:type="archimate:Node" name="Azure OpenAI service" id="id-node-openaisvc"/>
    <element xsi:type="archimate:Node" name="Cosmos DB account" id="id-node-cosmossvc"/>
    <element xsi:type="archimate:Node" name="Entra ID tenant (Ecolab)" id="id-node-entraid"/>
    <element xsi:type="archimate:Node" name="SharePoint Online tenant (Ecolab)" id="id-node-sharepoint"/>
    <element xsi:type="archimate:TechnologyService" name="Private endpoint" id="id-tech-privateep"/>
    <element xsi:type="archimate:TechnologyService" name="Virtual Network" id="id-tech-vnet"/>
    <element xsi:type="archimate:TechnologyService" name="Application Insights" id="id-tech-appinsights"/>
  </folder>
  <folder name="Relations" id="id-relations" type="relations">
    <!-- Motivation relationships -->
    <element xsi:type="archimate:InfluenceRelationship" id="rel-inf1" source="id-stakeholder-legal" target="id-driver-permissions"/>
    <element xsi:type="archimate:InfluenceRelationship" id="rel-inf2" source="id-stakeholder-itops" target="id-goal-fastpilot"/>
    <element xsi:type="archimate:InfluenceRelationship" id="rel-inf3" source="id-driver-search" target="id-goal-fastpilot"/>
    <element xsi:type="archimate:InfluenceRelationship" id="rel-inf4" source="id-driver-permissions" target="id-goal-citations"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real1" source="id-req-multiturn" target="id-goal-multiturn"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real2" source="id-req-acl" target="id-goal-citations"/>
    <!-- Business to Application -->
    <element xsi:type="archimate:ServingRelationship" id="rel-serv1" source="id-service-answer" target="id-actor-frontline"/>
    <element xsi:type="archimate:ServingRelationship" id="rel-serv2" source="id-service-citation" target="id-actor-supervisor"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real3" source="id-comp-bot" target="id-service-answer"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real4" source="id-comp-bot" target="id-intf-chat"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real5" source="id-comp-orchestrator" target="id-intf-search"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real6" source="id-comp-orchestrator" target="id-intf-completion"/>
    <element xsi:type="archimate:CompositionRelationship" id="rel-comp1" source="id-comp-bot" target="id-comp-orchestrator"/>
    <!-- Application internal flows -->
    <element xsi:type="archimate:FlowRelationship" id="rel-flow1" source="id-svc-acltrim" target="id-ext-sharepoint"/>
    <element xsi:type="archimate:FlowRelationship" id="rel-flow2" source="id-comp-orchestrator" target="id-svc-acltrim"/>
    <element xsi:type="archimate:FlowRelationship" id="rel-flow3" source="id-comp-orchestrator" target="id-comp-search"/>
    <element xsi:type="archimate:FlowRelationship" id="rel-flow4" source="id-comp-orchestrator" target="id-comp-openai"/>
    <element xsi:type="archimate:FlowRelationship" id="rel-flow5" source="id-comp-orchestrator" target="id-comp-cosmos"/>
    <element xsi:type="archimate:AccessRelationship" id="rel-access1" source="id-comp-orchestrator" target="id-data-convstate"/>
    <element xsi:type="archimate:FlowRelationship" id="rel-flow6" source="id-comp-openai" target="id-ext-sharepoint"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real7" source="id-comp-search" target="id-svc-indexer"/>
    <!-- Technology realization -->
    <element xsi:type="archimate:RealizationRelationship" id="rel-real8" source="id-node-appsvc" target="id-comp-bot"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real9" source="id-node-appsvc" target="id-comp-orchestrator"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real10" source="id-node-searchsvc" target="id-comp-search"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real11" source="id-node-cosmossvc" target="id-comp-cosmos"/>
    <element xsi:type="archimate:RealizationRelationship" id="rel-real12" source="id-node-openaisvc" target="id-comp-openai"/>
    <!-- Technology services -->
    <element xsi:type="archimate:ServingRelationship" id="rel-serv3" source="id-tech-privateep" target="id-tech-vnet"/>
    <element xsi:type="archimate:ServingRelationship" id="rel-serv4" source="id-node-searchsvc" target="id-tech-privateep"/>
    <element xsi:type="archimate:ServingRelationship" id="rel-serv5" source="id-node-openaisvc" target="id-tech-privateep"/>
    <element xsi:type="archimate:ServingRelationship" id="rel-serv6" source="id-node-cosmossvc" target="id-tech-privateep"/>
    <element xsi:type="archimate:ServingRelationship" id="rel-serv7" source="id-node-appsvc" target="id-tech-privateep"/>
    <element xsi:type="archimate:ServingRelationship" id="rel-serv8" source="id-tech-appinsights" target="id-node-appsvc"/>
    <!-- Additional associations for clarity -->
    <element xsi:type="archimate:AssociationRelationship" id="rel-assoc1" source="id-tech-vnet" target="id-node-appsvc"/>
    <element xsi:type="archimate:AssociationRelationship" id="rel-assoc2" source="id-tech-vnet" target="id-node-searchsvc"/>
    <element xsi:type="archimate:AssociationRelationship" id="rel-assoc3" source="id-tech-vnet" target="id-node-openaisvc"/>
    <element xsi:type="archimate:AssociationRelationship" id="rel-assoc4" source="id-tech-vnet" target="id-node-cosmossvc"/>
    <!-- OAuth flow -->
    <element xsi:type="archimate:ServingRelationship" id="rel-serv9" source="id-comp-bot" target="id-svc-obo"/>
    <element xsi:type="archimate:ServingRelationship" id="rel-serv10" source="id-svc-obo" target="id-ext-entraid"/>
  </folder>
  <folder name="Views" id="id-views" type="diagrams">
    <element xsi:type="archimate:ArchimateDiagramModel" name="Layered View" id="id-diagram-layered">
      <!-- The diagram object positions will be added by the tool automatically -->
    </element>
  </folder>
</archimate:model>
